{
  "uid": "quicknotes-golden-signals",
  "title": "QuickNotes Golden Signals",
  "tags": ["quicknotes", "sre", "golden-signals"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Traffic - requests/sec",
      "description": "Golden signal: Traffic. rate() of total HTTP requests handled by QuickNotes.",
      "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
          "expr": "sum(rate(quicknotes_http_requests_total[$__rate_interval]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Errors - 4xx+5xx ratio",
      "description": "Golden signal: Errors. Ratio of 4xx+5xx responses to all responses. The red threshold marks the 5% page line (see the high-error-rate alert).",
      "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
          "expr": "sum(rate(quicknotes_http_responses_by_code_total{code=~\"4..|5..\"}[$__rate_interval])) / clamp_min(sum(rate(quicknotes_http_responses_by_code_total[$__rate_interval])), 1e-9)",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency (proxy) - request rate by status code",
      "description": "Golden signal: Latency. QuickNotes exposes no request-duration histogram, so per-status request rate stands in as the proxy the lab allows.",
      "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
          "expr": "sum by (code) (rate(quicknotes_http_responses_by_code_total[$__rate_interval]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saturation - notes stored",
      "description": "Golden signal: Saturation. quicknotes_notes_total gauge - how full the note store is.",
      "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "quicknotes-prometheus" },
          "expr": "quicknotes_notes_total",
          "legendFormat": "notes stored"
        }
      ]
    }
  ]
}
